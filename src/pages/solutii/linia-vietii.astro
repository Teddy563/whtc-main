const color = "#1e3a8a";

// ─── Category shades ──────────────────────────────────────────────────────────
const VERT = "#1e3a8a"; // main blue
const HORIZ = "#0f2266"; // darker blue
const TEMP = "#122680"; // mid blue
---

<Layout
    title="Sisteme Linia Vieții: Verticale, Orizontale si Temporare | WHTC Inginerie"
    description="Proiectăm, instalăm și certificăm sisteme Linia Vieții EN 795 și EN 353-1. Verticale, orizontale și temporare, din Inox 316, cu verificare anuală inclusă."
>
