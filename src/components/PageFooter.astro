---
import { Image } from "astro:assets";
import safetyLogo from "../assets/whtc_white.svg";

const currentYear = new Date().getFullYear();
---

<footer id="footer" class="bg-brand-black text-white py-8 px-6">
    <div
        class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-6"
    >
        <!-- Brand & About -->
        <div class="max-w-xs">
            <Image
                src={safetyLogo}
                alt="Safety Academy Logo"
                class="h-10 w-auto mb-3"
            />
            <p
                class="text-gray-400 text-xs leading-relaxed"
                data-i18n="footer_about"
            >
                Încă de la începutul anilor 2000, ne-am dedicat furnizării celor
                mai sigure și eficiente servicii de lucru la înălțime din
                România. Certificați ISO 9001, 14001, 45001.
            </p>
        </div>

        <!-- Contact -->
        <div
            class="flex flex-col md:flex-row gap-6 md:gap-12 text-sm text-gray-400"
        >
            <div class="flex flex-col">
                <span class="text-white font-bold" data-i18n="footer_hq"
                    >Sediu Central</span
                >
                <span>Str. Intrarea Craiovei, nr. 43, Sector 6, București</span>
            </div>
            <div class="flex flex-col">
                <span class="text-white font-bold" data-i18n="footer_touch"
                    >Email &amp; Telefon</span
                >
                <a
                    href="mailto:office@whtc.ro"
                    class="hover:text-white transition-colors">office@whtc.ro</a
                >
                <a
                    href="tel:+40749225956"
                    class="hover:text-white transition-colors"
                    >+40 749 225 956</a
                >
            </div>
        </div>
    </div>

    <div
        class="max-w-7xl mx-auto mt-8 pt-4 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center text-xs text-gray-600 gap-4"
    >
        <p>&copy; {currentYear} Working at Height Training Center SRL.</p>
        <div class="flex gap-6">
            <a
                href="/politica-confidentialitate/"
                data-i18n="footer_privacy"
                class="hover:text-gray-400 transition-colors"
                >Politica de Confidențialitate</a
            >
            <a
                href="/termeni-si-conditii/"
                data-i18n="footer_terms"
                class="hover:text-gray-400 transition-colors"
                >Termeni și Condiții</a
            >
        </div>
    </div>
</footer>
