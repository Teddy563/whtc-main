---
/**
 * SubPageHero — compact hero for /solutii/* sub-pages.
 *
 * Props:
 *   title      — main H1 (HTML allowed for <br/> breaks)
 *   subtitle   — small text below title (plain string)
 *   badge      — category label shown in coloured pill above H1
 *   color      — hex for badge bg and tint overlay
 *   bgImage    — background: imported ImageMetadata OR a URL string
 *   ctaPrimary — opens contact drawer { label, subject }
 *   ctaScroll  — smooth-scrolls to page section { label, anchor }
 */

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface CtaPrimary {
    label: string;
    subject: string;
}

interface CtaScroll {
    label: string;
    anchor: string;
}

interface Props {
    title: string;
    subtitle?: string;
    badge?: string;
    color?: string;
    bgImage?: string | ImageMetadata;
    ctaPrimary?: CtaPrimary;
    ctaScroll?: CtaScroll;
}

const {
    title,
    subtitle,
    badge,
    color = "#f16215",
    bgImage,
    ctaPrimary,
    ctaScroll,
} = Astro.props;

const bgIsLocal = bgImage && typeof bgImage !== "string";
const hasCtas = ctaPrimary || ctaScroll;
---

<section
    class="sub-hero relative bg-black text-white overflow-hidden flex flex-col justify-center"
>
    {/* Tinted colour wash */}
    <div
        class="absolute inset-0 z-0 pointer-events-none"
        style={`background:${color}; opacity:0.13;`}
    >
    </div>

    {/* Background image */}
    {
        bgImage && (
            <div class="absolute inset-0 z-0 pointer-events-none">
                {bgIsLocal ? (
                    <Image
                        src={bgImage as ImageMetadata}
                        alt=""
                        aria-hidden="true"
                        width={1600}
                        class="w-full h-full object-cover"
                        style="opacity:0.25; filter:grayscale(60%) contrast(1.15);"
                        loading="eager"
                        fetchpriority="high"
                        quality={60}
                        format="webp"
                    />
                ) : (
                    <Image
                        src={bgImage as string}
                        alt=""
                        aria-hidden="true"
                        width={1920}
                        height={1080}
                        inferSize={true}
                        class="w-full h-full object-cover"
                        style="opacity:0.20; filter:grayscale(70%) contrast(1.15);"
                        loading="eager"
                        fetchpriority="high"
                        quality={60}
                        format="webp"
                    />
                )}
                <div
                    class="absolute inset-0"
                    style="background:linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0.65) 100%);"
                />
            </div>
        )
    }

    {/* Accent stripe at very top */}
    <div
        class="absolute top-0 left-0 right-0 h-[3px] z-10"
        style={`background:${color};`}
    >
    </div>

    {/* Centered content */}
    <div
        class="relative z-10 max-w-4xl mx-auto w-full px-5 lg:px-8 text-center py-8"
    >
        {/* Badge */}
        {
            badge && (
                <span
                    class="inline-block py-1 px-3 mb-4 font-montserrat font-black text-[9px] uppercase tracking-widest text-white"
                    style={`background:${color};`}
                >
                    {badge}
                </span>
            )
        }

        {/* Title */}
        <h1
            class="hero-title font-montserrat font-black uppercase leading-none tracking-tighter mb-4 text-white"
            set:html={title}
        />

        {/* Subtitle */}
        {
            subtitle && (
                <p
                    class="text-white/60 max-w-2xl mx-auto font-montserrat font-bold uppercase tracking-widest text-[10px] md:text-xs leading-relaxed"
                    set:html={subtitle}
                />
            )
        }

        {/* CTA buttons */}
        {
            hasCtas && (
                <div class="flex flex-col sm:flex-row flex-wrap gap-3 justify-center mt-6 lg:mt-8">
                    {ctaPrimary && (
                        <button
                            onclick={`openContactDrawer('${ctaPrimary.subject}', '${color}')`}
                            class="hero-cta-primary flex items-center justify-center gap-2 px-7 py-3.5 font-montserrat font-black text-[11px] uppercase tracking-widest text-white transition-all duration-300"
                            style={`--hc:${color};`}
                        >
                            <svg
                                class="w-4 h-4 flex-shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                />
                            </svg>
                            {ctaPrimary.label}
                        </button>
                    )}
                    {ctaScroll && (
                        <a
                            href={`#${ctaScroll.anchor}`}
                            onclick={`event.preventDefault();const el=document.getElementById('${ctaScroll.anchor}');if(el){window.scrollTo({top:el.getBoundingClientRect().top+window.scrollY-80,behavior:'smooth'});}`}
                            class="flex items-center justify-center gap-2 px-7 py-3.5 font-montserrat font-black text-[11px] uppercase tracking-widest text-white border-2 border-white/30 hover:border-white hover:bg-white/10 transition-all duration-300"
                        >
                            {ctaScroll.label}
                            <svg
                                class="w-4 h-4 flex-shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"
                                />
                            </svg>
                        </a>
                    )}
                </div>
            )
        }
    </div>
</section>

<style>
    .sub-hero {
        /* Navbar is 80px fixed; hero sits below it */
        padding-top: 80px;
        /* 60% of the full viewport height */
        height: 60vh;
        min-height: 380px;
        max-height: 620px;
    }

    .hero-title {
        /* Big and bold — scales smoothly from mobile to widescreen */
        font-size: clamp(2.2rem, 5.5vw, 5rem);
        /* Ensure max 2 lines — let each <br/> in the markup control the break */
    }

    .hero-cta-primary {
        background: var(--hc);
        cursor: pointer;
        border: 2px solid var(--hc);
    }
    .hero-cta-primary:hover {
        background: #111;
        border-color: #111;
    }
</style>
