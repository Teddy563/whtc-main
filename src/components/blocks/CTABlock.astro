---
/**
 * CTABlock — conversion section with a headline and one or two action buttons.
 *
 * Props:
 *   heading    — main headline (HTML allowed for <br/>)
 *   body       — supportive body text
 *   ctaLabel   — primary button label
 *   ctaSubject — subject passed to openContactDrawer()
 *   emailHref  — optional secondary email link (shows mailto button)
 *   color      — accent colour for primary button hover (default: brand-orange)
 *   dark       — if true renders black bg with white text
 */

interface Props {
    heading?: string;
    body?: string;
    ctaLabel?: string;
    ctaSubject?: string;
    emailHref?: string;
    color?: string;
    dark?: boolean;
    accentBackground?: boolean;
}

const {
    heading = "Hai să discutăm<br/>proiectul tău",
    body = "Evaluare gratuită la sediul dumneavoastră. Fără obligații.",
    ctaLabel = "Solicită Evaluare",
    ctaSubject = "General Inquiry",
    emailHref,
    color = "#f16215",
    dark = false,
    accentBackground = false,
} = Astro.props;

const sectionBg = accentBackground ? "" : (dark ? "bg-brand-black" : "bg-white");
const sectionStyle = accentBackground ? `background: ${color};` : "";
const headingColor = (dark || accentBackground) ? "text-white" : "text-brand-black";
const bodyColor = (dark || accentBackground) ? "text-white/80" : "text-gray-500";
const boxBorderClass = accentBackground 
    ? "border-white/20 bg-black/10" 
    : (dark ? "border-white/10 bg-white/5" : "border-gray-200 bg-gray-50");
---

<section class={`py-16 lg:py-20 px-5 ${sectionBg}`} style={sectionStyle}>
    <div class="max-w-7xl mx-auto">
        <div class={`border-2 p-6 lg:p-10 grid md:grid-cols-5 gap-6 items-center ${boxBorderClass}`}>
            <div class="md:col-span-3">
                <h3
                    class={`font-montserrat font-black text-2xl lg:text-3xl uppercase leading-none mb-3 ${headingColor}`}
                    set:html={heading}
                />
                {body && (
                    <p class={`text-sm leading-relaxed ${bodyColor}`}>{body}</p>
                )}
            </div>

            <div class="md:col-span-2 flex flex-col gap-3">
                <button
                    onclick={`openContactDrawer('${ctaSubject}', '${color}')`}
                    class={`font-montserrat font-black uppercase text-xs tracking-widest flex items-center justify-center gap-3 px-6 py-4 transition-colors duration-300 ${accentBackground ? 'bg-white text-brand-black hover:bg-gray-200' : 'cta-primary text-white'}`}
                    style={!accentBackground ? `--cc:${color};` : ''}
                >
                    <!-- Phone icon -->
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z">
                        </path>
                    </svg>
                    {ctaLabel}
                </button>

                {emailHref && (
                    <a
                        href={`mailto:${emailHref}`}
                        class={`flex items-center justify-center gap-3 border-2 px-6 py-4 font-montserrat font-black uppercase text-xs tracking-widest transition-colors duration-300 ${accentBackground ? "border-white/30 text-white hover:border-white hover:bg-white/10" : (dark ? "border-white/20 text-white hover:border-white hover:bg-white/5" : "border-black text-brand-black hover:bg-black hover:text-white")}`}
                    >
                        <!-- Email icon -->
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                            </path>
                        </svg>
                        {emailHref}
                    </a>
                )}
            </div>
        </div>
    </div>
</section>

<style>
    .cta-primary {
        background: #111;
        transition: background 0.3s;
        cursor: pointer;
    }
    .cta-primary:hover {
        background: var(--cc);
    }
</style>
