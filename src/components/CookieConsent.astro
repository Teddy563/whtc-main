---
/**
 * CookieConsent.astro
 * Standard GDPR / Consent Mode v2 implementation.
 */
import { Icon } from "astro-icon/components";

// Get keys from Astro.props or process.env
const GA_ID = import.meta.env.PUBLIC_GA_ID;
const CLARITY_ID = import.meta.env.PUBLIC_CLARITY_ID || "unlwwm2waf";
const COOKIE_NAME = "whtc_consent_v2";
const COOKIE_MAX_AGE_DAYS = 180;
---

<div
    id="cookie-consent-popup"
    class="fixed bottom-4 left-4 w-[calc(100%-2rem)] md:left-6 md:w-[420px] bg-white border border-gray-200 z-[200] transform translate-y-[150%] opacity-0 transition-all duration-700 ease-[cubic-bezier(0.87,0,0.13,1)] shadow-2xl flex flex-col pointer-events-none p-5 rounded-none"
>
    <div class="flex items-start gap-4">
        <div class="text-[#f16215] flex-shrink-0 mt-0.5">
            <Icon name="mdi:cookie-alert" class="w-8 h-8" />
        </div>

        <div class="flex-1 w-full pr-2">
            <h3
                class="text-[12px] font-black uppercase tracking-[0.1em] text-black font-montserrat mb-2 flex items-center gap-2"
            >
                Gestionare Cookie-uri
            </h3>

            <p
                class="text-[11px] font-medium text-gray-600 mb-4 leading-relaxed"
            >
                Utilizăm cookie-uri necesare pentru funcționarea site-ului. De
                asemenea, folosim cookie-uri adiționale pentru statistici și
                marketing, cu scopul de a-ți oferi o experiență mai relevantă și
                îmbunătățită.
                <a
                    href="/politica-cookies"
                    class="underline text-black decoration-[#f16215] inline-block mt-1"
                    >Politica de confidențialitate</a
                >.
            </p>

            <div class="flex flex-col gap-2 w-full mt-2">
                <button
                    id="cookie-accept-all-btn"
                    class="w-full bg-[#f16215] border border-[#f16215] text-white px-4 py-3 text-[11px] font-black uppercase tracking-[0.1em] hover:bg-black hover:border-black transition-colors rounded-none"
                >
                    Acceptă
                </button>
                <button
                    id="cookie-necessary-btn"
                    class="w-full text-gray-400 hover:text-black py-2.5 text-[11px] font-bold uppercase tracking-[0.1em] transition-colors rounded-none"
                >
                    Respinge
                </button>
            </div>
        </div>
    </div>
</div>

<script
    is:inline
    define:vars={{ GA_ID, CLARITY_ID, COOKIE_NAME, COOKIE_MAX_AGE_DAYS }}
>
    // Utility for cookies
    function setConsentCookie(name, value, days) {
        const d = new Date();
        d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
        document.cookie = `${name}=${value}; expires=${d.toUTCString()}; path=/; SameSite=Lax; ${location.protocol === "https:" ? "Secure" : ""}`;
    }

    function getConsentCookie(name) {
        const nameEQ = name + "=";
        const ca = document.cookie.split(";");
        for (let i = 0; i < ca.length; i++) {
            let c = ca[i];
            while (c.charAt(0) == " ") c = c.substring(1, c.length);
            if (c.indexOf(nameEQ) == 0)
                return c.substring(nameEQ.length, c.length);
        }
        return null;
    }

    // Load Clarity (GA4 is handled via Layout.astro or GTM)
    function loadClarity() {
        if (!CLARITY_ID || window.clarity) return;
        (function (c, l, a, r, i, t, y) {
            c[a] =
                c[a] ||
                function () {
                    (c[a].q = c[a].q || []).push(arguments);
                };
            t = l.createElement(r);
            t.async = 1;
            t.src = "https://www.clarity.ms/tag/" + i;
            y = l.getElementsByTagName(r)[0];
            y.parentNode.insertBefore(t, y);
        })(window, document, "clarity", "script", CLARITY_ID);
    }

    function updateGtagConsent(choice) {
        if (typeof gtag !== "function") return;

        if (choice === "all") {
            gtag("consent", "update", {
                analytics_storage: "granted",
                ad_storage: "granted",
                ad_user_data: "granted",
                ad_personalization: "granted",
            });
            // Fire manual page_view now that we have consent
            if (GA_ID) gtag("event", "page_view", { send_to: GA_ID });
            loadClarity();
        } else {
            gtag("consent", "update", {
                analytics_storage: "denied",
                ad_storage: "denied",
                ad_user_data: "denied",
                ad_personalization: "denied",
            });
        }
    }

    function initCookieBanner() {
        const popup = document.getElementById("cookie-consent-popup");
        const existing = getConsentCookie(COOKIE_NAME);

        if (!existing) {
            setTimeout(() => {
                if (popup)
                    popup.classList.remove(
                        "translate-y-[150%]",
                        "opacity-0",
                        "pointer-events-none",
                    );
            }, 1500);
        } else {
            updateGtagConsent(existing);
        }

        document
            .getElementById("cookie-accept-all-btn")
            ?.addEventListener("click", () => {
                setConsentCookie(COOKIE_NAME, "all", COOKIE_MAX_AGE_DAYS);
                updateGtagConsent("all");
                if (popup)
                    popup.classList.add(
                        "translate-y-[150%]",
                        "opacity-0",
                        "pointer-events-none",
                    );
            });

        document
            .getElementById("cookie-necessary-btn")
            ?.addEventListener("click", () => {
                setConsentCookie(COOKIE_NAME, "necessary", COOKIE_MAX_AGE_DAYS);
                updateGtagConsent("necessary");
                if (popup)
                    popup.classList.add(
                        "translate-y-[150%]",
                        "opacity-0",
                        "pointer-events-none",
                    );
            });
    }

    // Start
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCookieBanner);
    } else {
        initCookieBanner();
    }
</script>
