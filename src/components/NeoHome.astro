<script is:inline>
    // Smooth video fade-in when ready (existing)
    const heroVideo = document.getElementById("hero-video");
    if (heroVideo) {
        heroVideo.addEventListener(
            "canplay",
            function () {
                heroVideo.classList.remove("opacity-0");
                heroVideo.classList.add("opacity-100");
            },
            { once: true },
        );
    }

    // Cycle "signal" hover effect on hero verticals
    const verticals = document.querySelectorAll(".hero-vertical");
    let currentVerticalIndex = 0;

    function cycleVerticals() {
        if (!verticals.length) return;

        // Remove signal class from all
        verticals.forEach((v) => v.classList.remove("signal-hover"));

        // Add signal class to current
        verticals[currentVerticalIndex].classList.add("signal-hover");

        // Prepare next index
        currentVerticalIndex = (currentVerticalIndex + 1) % verticals.length;
    }

    // Start the cycle
    if (verticals.length > 0) {
        // Run immediately first time
        cycleVerticals();
        // Then every 3 seconds
        setInterval(cycleVerticals, 3000);
    }

    // ── Desktop dropdown nav (smooth, no backdrop, no scroll lock) ──────
    window.toggleDeskNav = function () {
        const panel = document.getElementById("desk-nav-panel");
        const iconMenu = document.getElementById("desk-nav-icon-menu");
        const iconClose = document.getElementById("desk-nav-icon-close");
        if (!panel) return;
        const isOpen = panel.classList.contains("desk-nav-panel-open");
        panel.classList.toggle("desk-nav-panel-open", !isOpen);
        panel.classList.toggle("desk-nav-panel-closed", isOpen);
        if (iconMenu) iconMenu.classList.toggle("hidden", !isOpen);
        if (iconClose) iconClose.classList.toggle("hidden", isOpen);
    };

    // Close desktop panel when clicking outside
    document.addEventListener("click", function (e) {
        const panel = document.getElementById("desk-nav-panel");
        const btn = document.getElementById("desk-nav-btn");
        if (
            panel &&
            panel.classList.contains("desk-nav-panel-open") &&
            !panel.contains(e.target) &&
            btn &&
            !btn.contains(e.target)
        ) {
            window.toggleDeskNav();
        }
    });

    window.toggleSolutiiSub = function () {
        const sub = document.getElementById("solutii-sub");
        const chevron = document.getElementById("solutii-chevron");
        if (!sub) return;
        const isOpen = !sub.classList.contains("hidden");
        sub.classList.toggle("hidden", isOpen);
        if (chevron) chevron.style.transform = isOpen ? "" : "rotate(180deg)";
    };

    // ── Mobile full-screen nav ──────────────────────────────────────────
    window.toggleMobNav = function () {
        const overlay = document.getElementById("mob-nav-overlay");
        const iconMenu = document.getElementById("mob-nav-icon-menu");
        const iconClose = document.getElementById("mob-nav-icon-close");
        if (!overlay) return;
        const isHidden = overlay.classList.contains("hidden");
        overlay.classList.toggle("hidden", !isHidden);
        iconMenu.classList.toggle("hidden", isHidden);
        iconClose.classList.toggle("hidden", !isHidden);
        document.body.style.overflow = isHidden ? "hidden" : "";
    };

    window.toggleMobSolutii = function () {
        const sub = document.getElementById("mob-solutii-sub");
        const chevron = document.getElementById("mob-solutii-chevron");
        if (!sub) return;
        const isOpen = !sub.classList.contains("hidden");
        sub.classList.toggle("hidden", isOpen);
        if (chevron) chevron.style.transform = isOpen ? "" : "rotate(180deg)";
    };
</script>

