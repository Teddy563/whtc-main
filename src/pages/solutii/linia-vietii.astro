import PageFooter from "../../components/PageFooter.astro";
import ContentSection from "../../components/blocks/ContentSection.astro";
import ProcessSteps from "../../components/blocks/ProcessSteps.astro";
import StatsStrip from "../../components/blocks/StatsStrip.astro";
import CTABlock from "../../components/blocks/CTABlock.astro";
import RelatedPages from "../../components/blocks/RelatedPages.astro";
import { Image } from "astro:assets";

import heroImg from "../../assets/solutii/sisteme_linia_vietii.gif";
import cablocImg from "../../assets/solutii/linia-vietii/cabloc.webp";
import scaraCrinolinaImg from "../../assets/solutii/linia-vietii/scara_crinolina.webp";
import ks9000Img from "../../assets/solutii/linia-vietii/ks9000.webp";
import liniaVietiiOrizontalaImg from "../../assets/solutii/linia-vietii/linia-vietii-orizontala.webp";
import rampaAutoImg from "../../assets/solutii/linia-vietii/sistem_orizontal_rampa_auto.webp";
import ezlineImg from "../../assets/solutii/linia-vietii/ezline.webp";
import chingaImg from "../../assets/solutii/linia-vietii/chinga.webp";
import sinaAluminiuImg from "../../assets/solutii/linia-vietii/sina_aluminiu.webp";
import factorCadereImg from "../../assets/solutii/linia-vietii/factorul_de_cadere.webp";

import liniaVietiiImgRelated from "../../assets/solutii/linia-vietii/linia-vietii-orizontala.webp";
import accesImgRelated from "../../assets/solutii/schela_mobila.webp";
import customImgRelated from "../../assets/solutii/solutii_custom.webp";
