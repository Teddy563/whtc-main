# ─── Email / Contact Form ────────────────────────────────────────────────────
# Resend API key — get yours at https://resend.com/api-keys
RESEND_API_KEY=re_123456789_your_key_here

# The "From" address shown in outgoing emails (must be a verified Resend domain)
SENDER_EMAIL="WHTC Website <no-reply@lockout-tagout.ro>"

# Comma-separated list of recipients for contact form submissions
CONTACT_EMAIL=office@lockout-tagout.ro,office@lttlock.com


# ─── Cloudflare Turnstile (CAPTCHA) ─────────────────────────────────────────
# Get both keys at: https://dash.cloudflare.com → Turnstile → Add Site
# PUBLIC_ prefix makes it available in the browser (safe to expose)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Secret key — NEVER expose this in the browser or commit the real value
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA


# ─── Google Analytics 4 (GA4) ────────────────────────────────────────────────
# Your GA4 Measurement ID — format: G-XXXXXXXXXX
# Find it in: GA4 Admin → Data Streams → Web → Measurement ID
# PUBLIC_ prefix required so Astro can inline it into the <head> script tag
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Google Tag Manager container ID (only if you use GTM instead of/alongside GA4)
# Format: GTM-XXXXXXX — found in GTM Admin → Container Settings
# PUBLIC_GTM_ID=GTM-XXXXXXX

# Optional: Google Ads conversion tracking ID (only if running Google Ads)
# Format: AW-XXXXXXXXXX — found in Google Ads → Tools → Conversions
# PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX