                    "description": "Expert în sisteme de protecție anticădere, WHTC proiectează, instalează și certifică sisteme Linia Vieții conforme EN 795 și EN 353-1."
                },
                "areaServed": {
                    "@type": "Country",
                    "name": "România"
                },
                "hasOfferCatalog": {
                    "@type": "OfferCatalog",
                    "name": "Sisteme Anticădere",
