---
/**
 * StatsStrip — horizontal strip of 4 key numbers/facts.
 *
 * Props:
 *   stats  — array of { num, label, sub }
 *   dark   — true = black bg (default), false = white bg with black text
 */

interface Stat {
    num: string;
    label: string;
    sub?: string;
}

interface Props {
    stats?: Stat[];
    dark?: boolean;
}

const defaultStats: Stat[] = [
    {
        num: "20+",
        label: "Ani de Experiență",
        sub: "Din 2004 pe piața din România",
    },
    {
        num: "500+",
        label: "Proiecte Finalizate",
        sub: "Hale, acoperișuri, structuri",
    },
    {
        num: "3M™",
        label: "Distribuitor Autorizat",
        sub: "Partener Certificat în România",
    },
    {
        num: "ISO",
        label: "9001 · 14001 · 45001",
        sub: "Certificări Internaționale",
    },
];

const { stats = defaultStats, dark = true } = Astro.props;

const bg = dark
    ? "bg-black text-white border-b-2 border-black"
    : "bg-white text-brand-black border-y-2 border-black";
const divider = dark
    ? "lg:divide-x lg:divide-white/10"
    : "lg:divide-x lg:divide-black/10";
const subColor = dark ? "text-white/50" : "text-gray-500";
---

<div class={`${bg}`}>
    <div
        class={`max-w-7xl mx-auto px-5 lg:px-8 py-8 lg:py-10 grid grid-cols-2 lg:grid-cols-4 gap-y-6 gap-x-4 lg:gap-0 ${divider}`}
    >
        {
            stats.map((s) => (
                <div class="lg:px-10 first:pl-0 last:pr-0">
                    <div class="font-montserrat font-black text-2xl lg:text-4xl leading-none mb-1">
                        {s.num}
                    </div>
                    <div class="font-montserrat font-black text-[10px] lg:text-xs uppercase tracking-widest mb-1 opacity-90">
                        {s.label}
                    </div>
                    {s.sub && (
                        <div
                            class={`text-[9px] lg:text-[10px] leading-snug ${subColor}`}
                        >
                            {s.sub}
                        </div>
                    )}
                </div>
            ))
        }
    </div>
</div>
