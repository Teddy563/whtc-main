        <meta
            name="keywords"
            content="linia vietii, sisteme linia vietii, protectie la inaltime, sisteme anticadere, EN 795, EN 353-1, WHTC, siguranta la inaltime, linie de viata, ancorare"
        />
        <meta property="og:type" content="service" />
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "Service",
                "serviceType": "Instalare Sisteme Linia Vieții și Protecție la Înălțime",
                "provider": {
                    "@type": "LocalBusiness",
                    "name": "WHTC - Working at Height Training Centre",
