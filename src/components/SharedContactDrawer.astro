---
// SharedContactDrawer.astro
---

<!-- Shared Contact Drawer -->
<div
    id="shared-contact-drawer"
    class="fixed inset-y-0 right-0 w-full sm:w-[420px] md:w-[500px] lg:w-[600px] bg-white z-[200] transform translate-x-full transition-transform duration-200 ease-out will-change-transform flex flex-col font-montserrat"
    style="max-height: 100dvh; max-height: 100vh;"
>
    <!-- Drawer Header -->
    <div
        id="drawer-header"
        class="flex items-center justify-between px-5 py-3 sm:px-7 sm:py-4 lg:px-5 lg:py-3 xl:px-7 xl:py-5 transition-colors duration-400 ease-in-out flex-shrink-0"
        style="background-color: #000000;"
    >
        <div>
            <h2
                class="text-xl sm:text-2xl lg:text-2xl xl:text-3xl font-black uppercase leading-none tracking-tighter text-white"
            >
                Contact
            </h2>
            <p
                id="drawer-subject-label"
                class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.15em] sm:tracking-[0.2em] mt-1.5 text-white/90"
            >
                General Inquiry
            </p>
        </div>
        <button
            onclick="closeContactDrawer()"
            aria-label="Închide fereastra de contact"
            class="p-2 sm:p-2.5 bg-black/10 hover:bg-black/20 text-white transition-colors duration-200 rounded-sm backdrop-blur-sm group flex-shrink-0 ml-3"
        >
            <svg
                class="w-5 h-5 sm:w-6 sm:h-6 transition-transform group-hover:rotate-90 duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M6 18L18 6M6 6l12 12"></path></svg
            >
        </button>
    </div>

    <!-- Drawer Body -->
    <div
        class="flex-grow overflow-y-auto px-4 py-4 sm:px-6 sm:py-5 md:px-8 md:py-6 lg:px-5 lg:py-4 xl:px-8 xl:py-7 bg-[#fafafa] flex flex-col"
    >
        <form
            id="drawer-form"
            class="space-y-3 sm:space-y-4 lg:space-y-3 xl:space-y-5 flex-grow"
        >
            <input
                type="hidden"
                id="drawer-subject"
                name="subject"
                value="General Inquiry"
            />
            <input type="hidden" name="browser" id="drawer-browser" />
            <input type="hidden" name="device" id="drawer-device" />
            <input type="hidden" name="source" id="drawer-source" />

            {/* Cloudflare Turnstile */}
            <script
                is:inline
                src="https://challenges.cloudflare.com/turnstile/v0/api.js"
                async
                defer></script>

            <div class="space-y-1.5 sm:space-y-2">
                <label
                    for="drawer-name"
                    class="block font-black text-[10px] uppercase tracking-[0.15em] text-gray-400 ml-1"
                    >Nume Complet <span class="text-red-500">*</span></label
                >
                <div class="relative">
                    <input
                        type="text"
                        id="drawer-name"
                        name="name"
                        required
                        class="w-full bg-white border-2 border-gray-200 px-4 py-2.5 sm:px-5 sm:py-3.5 lg:py-2 xl:py-3.5 text-sm font-bold text-gray-800 placeholder-gray-300 focus:outline-none focus:border-black transition-colors rounded-none outline-none appearance-none"
                        placeholder="EX: ION POPESCU"
                    />
                </div>
            </div>

            <div
                class="grid grid-cols-1 xs:grid-cols-2 sm:grid-cols-2 gap-3 sm:gap-5"
            >
                <div class="space-y-1.5 sm:space-y-2">
                    <label
                        for="drawer-email"
                        class="block font-black text-[10px] uppercase tracking-[0.15em] text-gray-400 ml-1"
                        >Email <span class="text-red-500">*</span></label
                    >
                    <input
                        type="email"
                        id="drawer-email"
                        name="email"
                        required
                        class="w-full bg-white border-2 border-gray-200 px-4 py-2.5 sm:px-5 sm:py-3.5 lg:py-2 xl:py-3.5 text-sm font-bold text-gray-800 placeholder-gray-300 focus:outline-none focus:border-black transition-colors rounded-none outline-none appearance-none"
                        placeholder="OFERTE@NUME.RO"
                    />
                </div>
                <div class="space-y-1.5 sm:space-y-2">
                    <label
                        for="drawer-phone"
                        class="block font-black text-[10px] uppercase tracking-[0.15em] text-gray-400 ml-1"
                        >Telefon <span class="text-red-500">*</span></label
                    >
                    <input
                        type="tel"
                        id="drawer-phone"
                        name="phone"
                        required
                        class="w-full bg-white border-2 border-gray-200 px-4 py-2.5 sm:px-5 sm:py-3.5 lg:py-2 xl:py-3.5 text-sm font-bold text-gray-800 placeholder-gray-300 focus:outline-none focus:border-black transition-colors rounded-none outline-none appearance-none"
                        placeholder="07XX XXX XXX"
                    />
                </div>
            </div>

            <div class="space-y-1.5 sm:space-y-2">
                <label
                    for="drawer-message"
                    class="block font-black text-[10px] uppercase tracking-[0.15em] text-gray-400 ml-1"
                    >Detalii Proiect</label
                >
                <textarea
                    id="drawer-message"
                    name="message"
                    required
                    class="w-full h-16 sm:h-24 lg:h-28 xl:h-40 bg-white border-2 border-gray-200 px-4 py-2.5 sm:px-5 sm:py-4 lg:py-3 xl:py-4 text-sm font-medium text-gray-800 placeholder-gray-300 focus:outline-none focus:border-black transition-colors resize-none rounded-none outline-none appearance-none"
                    placeholder="DESCRIE PE SCURT CERINTELE TALE..."></textarea>
            </div>

            <div class="pt-0 overflow-hidden">
                <!-- Turnstile wrapper: scales down on narrow screens so it never overflows -->
                <div id="turnstile-wrapper" style="transform-origin: left top;">
                    <div
                        class="cf-turnstile"
                        data-sitekey={`${import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "1x00000000000000000000AA"}`}
                        data-theme="light"
                    >
                    </div>
                </div>
            </div>

            <button
                type="submit"
                id="drawer-submit-btn"
                class="w-full text-white py-2.5 sm:py-4 lg:py-4 xl:py-5 font-black uppercase tracking-[0.1em] sm:tracking-[0.2em] text-xs flex items-center justify-center gap-3 mt-1 sm:mt-4 lg:mt-3 xl:mt-5 rounded-none border-2 border-black transition-all ease-in-out hover:brightness-110 active:scale-[0.98]"
                style="background-color: #000000;"
            >
                <span>Trimite Solicitarea</span>
            </button>

            <div
                id="drawer-form-status"
                class="hidden text-center text-xs font-bold p-4 mt-4 border-2"
            >
            </div>
        </form>

        <!-- Small Contact Info at bottom -->
        <div
            class="mt-3 sm:mt-6 lg:mt-3 xl:mt-8 pt-3 sm:pt-4 lg:pt-3 xl:pt-5 border-t-2 border-gray-200 flex-shrink-0"
        >
            <div
                class="flex flex-row items-stretch justify-center gap-2 sm:gap-3"
            >
                <a
                    href="tel:+40749225956"
                    class="flex-1 flex items-center justify-center gap-2 p-2.5 sm:p-3 border-2 border-gray-200 hover:border-black hover:bg-black hover:text-white transition-all duration-300 rounded-none group bg-white min-w-0"
                >
                    <svg
                        class="w-3.5 h-3.5 sm:w-4 sm:h-4 opacity-50 group-hover:opacity-100 transition-opacity flex-shrink-0"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                        ></path></svg
                    >
                    <span
                        class="text-[9px] sm:text-[10px] uppercase font-black tracking-wider sm:tracking-widest truncate"
                        >+40 749 225 956</span
                    >
                </a>
                <a
                    href="mailto:office@whtc.ro"
                    class="flex-1 flex items-center justify-center gap-2 p-2.5 sm:p-3 border-2 border-gray-200 hover:border-black hover:bg-black hover:text-white transition-all duration-300 rounded-none group bg-white min-w-0"
                >
                    <svg
                        class="w-3.5 h-3.5 sm:w-4 sm:h-4 opacity-50 group-hover:opacity-100 transition-opacity flex-shrink-0"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path></svg
                    >
                    <span
                        class="text-[9px] sm:text-[10px] uppercase font-black tracking-wider sm:tracking-widest truncate"
                        >OFFICE@WHTC.RO</span
                    >
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Overlay -->
<div
    id="shared-drawer-overlay"
    onclick="closeContactDrawer()"
    class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[150] opacity-0 pointer-events-none transition-all duration-200 ease-out will-change-[opacity]"
>
</div>

<script is:inline>
    // Extract dynamic color from the click event if available, or fall back to argument
    window.openContactDrawer = function (
        subject = "General Inquiry",
        color = null,
    ) {
        const drawer = document.getElementById("shared-contact-drawer");
        const overlay = document.getElementById("shared-drawer-overlay");
        const subjectInput = document.getElementById("drawer-subject");
        const subjectLabel = document.getElementById("drawer-subject-label");
        const header = document.getElementById("drawer-header");
        const submitBtn = document.getElementById("drawer-submit-btn");

        // Attempt to find color from event context if 'color' argument isn't provided explicitly
        let dynamicColor = color || "#000000"; // default fallback is black

        if (!color && window.event) {
            let el = window.event.currentTarget || window.event.target;
            while (el && el !== document && el.tagName) {
                const styleAttr = el.getAttribute("style");
                if (styleAttr && styleAttr.includes("--cta:")) {
                    const match = styleAttr.match(/--cta:\s*(#[^\s;]+)/);
                    if (match) {
                        dynamicColor = match[1];
                        break;
                    }
                }
                const bg = window.getComputedStyle(el).backgroundColor;
                if (
                    bg &&
                    bg !== "rgba(0, 0, 0, 0)" &&
                    bg !== "transparent" &&
                    bg !== "rgb(255, 255, 255)"
                ) {
                    // Try to avoid picking up pure white
                    dynamicColor = bg;
                    break;
                }
                el = el.parentElement;
            }
        }

        if (drawer && overlay) {
            drawer.classList.remove("translate-x-full");
            overlay.classList.remove("opacity-0", "pointer-events-none");

            // Set subject
            if (subjectInput) subjectInput.value = subject;
            if (subjectLabel) subjectLabel.textContent = subject;

            // Set dynamic color
            if (header) header.style.backgroundColor = dynamicColor;
            if (submitBtn) {
                submitBtn.style.backgroundColor = dynamicColor;
                submitBtn.style.borderColor = dynamicColor;
            }

            // ── GTM: Track drawer open with niche context ─────────────────
            var niche = "general";
            if (/training|curs|gwo|alpinism|inaltime/i.test(subject))
                niche = "training";
            else if (/loto|lockout|control.energii|ltt/i.test(subject))
                niche = "loto";
            else if (
                /inginerie|solutii|sisteme|linie|ancore|engineering/i.test(
                    subject,
                )
            )
                niche = "engineering";

            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
                event: "drawer_open",
                contact_subject: subject,
                contact_niche: niche,
                page_path: window.location.pathname,
            });
            if (typeof window.gtag === "function") {
                window.gtag("event", "contact_intent", {
                    event_category: "Engagement",
                    event_label: subject,
                    contact_niche: niche,
                });
            }
            // ─────────────────────────────────────────────────────────────

            // Prevent body scroll and layout shift
            const scrollbarWidth =
                window.innerWidth - document.documentElement.clientWidth;
            document.body.style.paddingRight = `${scrollbarWidth}px`;
            const globalNavbar = document.getElementById("global-navbar");
            if (globalNavbar) {
                globalNavbar.style.paddingRight = `${scrollbarWidth}px`;
            }
            document.body.style.overflow = "hidden";

            // Close phone dropdown if open
            const dd = document.getElementById("phone-dropdown");
            if (dd && !dd.classList.contains("hidden")) {
                dd.classList.add("hidden");
                dd.classList.remove("flex");
            }

            // Scale Turnstile widget to fit inside drawer on small screens
            // Turnstile renders at a fixed ~300px wide; scale it down if drawer is narrower
            setTimeout(() => {
                const wrapper = document.getElementById("turnstile-wrapper");
                if (wrapper) {
                    // Padding on each side is ~16px (px-4) on mobile, total ~32px
                    const drawerEl = document.getElementById(
                        "shared-contact-drawer",
                    );
                    const bodyPadding = window.innerWidth >= 640 ? 48 : 32; // sm:px-6 = 24*2, px-4 = 16*2
                    const availableWidth =
                        (drawerEl ? drawerEl.offsetWidth : window.innerWidth) -
                        bodyPadding;
                    const widgetWidth = 300; // Turnstile fixed width
                    if (availableWidth < widgetWidth) {
                        const scale = availableWidth / widgetWidth;
                        wrapper.style.transform = `scale(${scale})`;
                        wrapper.style.height = `${Math.round(65 * scale)}px`; // Roughly 65px tall when scaled
                    } else {
                        wrapper.style.transform = "";
                        wrapper.style.height = "";
                    }
                }
            }, 50);
        }
    };

    window.closeContactDrawer = function () {
        const drawer = document.getElementById("shared-contact-drawer");
        const overlay = document.getElementById("shared-drawer-overlay");

        if (drawer && overlay) {
            drawer.classList.add("translate-x-full");
            overlay.classList.add("opacity-0", "pointer-events-none");

            // Restore body scroll after transition completes (200ms)
            setTimeout(() => {
                // Only restore if drawer is still actually hidden, to prevent race conditions
                if (drawer.classList.contains("translate-x-full")) {
                    document.body.style.overflow = "";
                    document.body.style.paddingRight = "";
                    const globalNavbar =
                        document.getElementById("global-navbar");
                    if (globalNavbar) {
                        globalNavbar.style.paddingRight = "";
                    }
                }
            }, 200);
        }
    };

    // Keep compatibility for NeoHome which uses toggleContact
    window.toggleContact = function (subject = "Contact General") {
        const drawer = document.getElementById("shared-contact-drawer");
        if (drawer && !drawer.classList.contains("translate-x-full")) {
            window.closeContactDrawer();
        } else {
            // Check if calling from the brutal block
            let color = "#000000"; // Default black for NeoHome
            window.openContactDrawer(subject, color);
        }
    };

    // Handle Form Submit
    const form = document.getElementById("drawer-form");
    if (form) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            // Populate Tracking
            const browserInput = document.getElementById("drawer-browser");
            const deviceInput = document.getElementById("drawer-device");
            const sourceInput = document.getElementById("drawer-source");

            if (browserInput) browserInput.value = navigator.userAgent;
            if (deviceInput) {
                const width = window.innerWidth;
                deviceInput.value =
                    width < 1024 ? "Mobile/Tablet" : "Desktop/Laptop";
            }
            if (sourceInput) sourceInput.value = window.location.href;

            const btn = document.getElementById("drawer-submit-btn");
            const status = document.getElementById("drawer-form-status");
            const originalBtnContent = btn.innerHTML;

            // Disable button and show loading state
            btn.disabled = true;
            btn.innerHTML = `<span>Se trimite...</span>`;
            status.classList.add("hidden");
            status.className =
                "text-center text-xs font-bold p-4 mt-4 border-2 hidden"; // reset classes

            try {
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());

                const response = await fetch("/api/contact", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify(data),
                });

                const responseText = await response.text();
                let result;
                try {
                    result = JSON.parse(responseText);
                } catch (e) {
                    console.error(
                        "Non-JSON Response from server:",
                        responseText,
                    );
                    throw new Error(
                        `Eroare de server (Ruta API nu a răspuns cu JSON). Status: ${response.status}`,
                    );
                }

                if (!response.ok) {
                    throw new Error(result.message || "A apărut o eroare.");
                }

                // Success
                form.reset();
                status.textContent =
                    "Mesaj trimis cu succes! Te vom contacta în curând.";
                status.classList.remove("hidden");
                status.classList.add(
                    "bg-green-50",
                    "text-green-700",
                    "border-green-600",
                );
                if (window.turnstile) window.turnstile.reset();

                // ── GTM + GA4: Lead Conversion Event ─────────────────────
                var formSubject =
                    document.getElementById("drawer-subject")?.value ||
                    "General Inquiry";
                var leadNiche = "general";
                if (/training|curs|gwo|alpinism|inaltime/i.test(formSubject))
                    leadNiche = "training";
                else if (/loto|lockout|control.energii|ltt/i.test(formSubject))
                    leadNiche = "loto";
                else if (
                    /inginerie|solutii|sisteme|linie|ancore|engineering/i.test(
                        formSubject,
                    )
                )
                    leadNiche = "engineering";

                // Push to dataLayer first (GTM picks this up for Ads Conversion tag)
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                    event: "form_submit_success",
                    lead_niche: leadNiche,
                    lead_subject: formSubject,
                    source_url: window.location.href,
                });

                // Also fire gtag directly for GA4
                if (typeof window.gtag === "function") {
                    window.gtag("event", "generate_lead", {
                        event_category: "Leads",
                        event_label: formSubject,
                        lead_niche: leadNiche,
                        source_url: window.location.href,
                    });
                }
                // ─────────────────────────────────────────────────────────

                // Close drawer after delay
                setTimeout(() => {
                    closeContactDrawer();
                    status.classList.add("hidden");
                    btn.innerHTML = originalBtnContent;
                }, 3000);
            } catch (error) {
                console.error("Error submitting form:", error);
                // @ts-ignore
                status.textContent =
                    error.message ||
                    "Eroare la trimitere. Te rugăm să încerci din nou sau să ne suni.";
                status.classList.remove("hidden");
                status.classList.add(
                    "bg-red-50",
                    "text-red-700",
                    "border-red-600",
                );
                btn.innerHTML = originalBtnContent;
                if (window.turnstile) window.turnstile.reset();
            } finally {
                btn.disabled = false;
            }
        });
    }
</script>
