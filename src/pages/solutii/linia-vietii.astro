            </nav>

            <!-- OVERVIEW STRIP -->
            <div
                class="bg-black/95 backdrop-blur-md text-white py-4 lg:py-6 border-t-[3px]"
                style={`border-color:${color};`}
            >
                <div
                    class="max-w-7xl mx-auto px-5 lg:px-8 grid md:grid-cols-3 gap-4 lg:gap-10"
                >
                    <!-- Description Left -->
                    <div class="md:col-span-2">
                        <h2
                            class="font-montserrat font-black text-lg lg:text-2xl uppercase leading-none mb-2 lg:mb-3"
                        >
                            Ce facem concret<br class="hidden md:block" />și de
                            ce contează
                        </h2>
                        <p
                            class="text-white/60 leading-snug text-xs lg:text-sm max-w-xl hidden md:block"
                        >
                            Mentenanță pe acoperiș, inspecție cisterne, urcare
                            pe turn. Fiecare situație cere un alt tip de
                            ancorare. WHTC calculează sarcina pe structura
