</Layout>

<!-- FLOATING NAV (Mobile Bottom, Desktop Right) -->
<div
    id="floating-nav-container"
    class="fixed z-50 bottom-4 left-1/2 -translate-x-1/2 lg:bottom-auto lg:top-1/2 lg:-translate-y-1/2 lg:left-auto lg:right-6 lg:translate-x-0 pointer-events-none"
>
    <nav
        id="floating-nav"
        class="flex flex-row lg:flex-col gap-2 transition-all duration-500 opacity-0 translate-y-12 lg:translate-y-0 lg:translate-x-12 pointer-events-none"
    >
        {
            [
                {
                    label: "Verticale",
                    sub: "EN 353-1",
                    anchor: "#verticala",
                    char: "V",
                },
                {
                    label: "Orizontale",
                    sub: "EN 795",
                    anchor: "#orizontala",
                    char: "O",
                },
                {
                    label: "Temporare",
                    sub: "EN 16415",
                    anchor: "#temporara",
                    char: "T",
                },
                {
                    label: "Selecție",
                    sub: "Ghid",
                    anchor: "#ghid",
                    char: "S",
                },
            ].map((t) => (
                <a
                    href={t.anchor}
                    class="group relative flex items-center justify-center pointer-events-auto floating-nav-link"
                    data-anchor={t.anchor.substring(1)}
                >
                    <div
                        class="hidden lg:block absolute right-full mr-4 bg-black/90 backdrop-blur px-4 py-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded border-r-4 whitespace-nowrap pointer-events-none"
                        style={`border-color: ${color};`}
                    >
                        <span class="font-montserrat font-black text-xs uppercase tracking-widest text-white leading-none block mb-1 text-right">
                            {t.label}
                        </span>
                        <span class="text-[10px] uppercase tracking-widest text-white/50 text-right block">
                            {t.sub}
                        </span>
                    </div>
                    <div class="nav-bubble w-10 h-10 lg:w-11 lg:h-11 rounded-full flex items-center justify-center transition-all bg-black group-hover:scale-110">
                        <span class="text-white font-montserrat font-bold text-sm relative z-10">
                            {t.char}
                        </span>
                    </div>
                </a>
            ))
        }
    </nav>
</div>

<style>
    .nav-bubble {
        background-color: #000;
    }
    .floating-nav-link.active .nav-bubble {
        background-color: #1e3a8a; /* Blue */
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const hero = document.querySelector("section"); // First section is hero
        const fnav = document.getElementById("floating-nav");

        if (hero && fnav) {
            window.addEventListener(
                "scroll",
                () => {
                    if (
                        window.scrollY >
                        (hero as HTMLElement).offsetHeight * 0.75
                    ) {
                        fnav.classList.remove(
                            "opacity-0",
                            "translate-y-12",
                            "lg:translate-x-12",
                            "pointer-events-none",
                        );
                    } else {
                        fnav.classList.add(
                            "opacity-0",
                            "translate-y-12",
                            "lg:translate-x-12",
                            "pointer-events-none",
                        );
                    }
                },
                { passive: true },
            );
        }

        // Intersection Observer for highlighting active section
        const sections = document.querySelectorAll("div[id]");
        const navLinks = document.querySelectorAll(".floating-nav-link");

        const observerOptions = {
            root: null,
            rootMargin: "-20% 0px -60% 0px",
            threshold: 0,
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const id = entry.target.getAttribute("id");
                    navLinks.forEach((link) => {
                        if (link.getAttribute("data-anchor") === id) {
                            link.classList.add("active");
                        } else {
                            link.classList.remove("active");
                        }
                    });
                }
            });
        }, observerOptions);

        sections.forEach((section) => {
            observer.observe(section);
        });
    });
</script>

