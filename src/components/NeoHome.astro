---
// Neo-Brutalist homepage design
import { Image, getImage } from "astro:assets";
import trainingImg from "../assets/training.webp";
import sistemeImg from "../assets/sisteme.webp";
import lotoImg from "../assets/loto.webp";
import iso3mImg from "../assets/iso_3m.webp";

import safetyVideo from "../assets/safety.mp4";
import npcImg from "../assets/npc1.webp";
import whtcLogo from "../assets/whtc.svg";
import SharedContactDrawer from "./SharedContactDrawer.astro";

const trainingBg = await getImage({
    src: trainingImg,
    format: "webp",
    width: 600,
    quality: 60,
});
const sistemeBg = await getImage({
    src: sistemeImg,
    format: "webp",
    width: 600,
    quality: 60,
});
const lotoBg = await getImage({
    src: lotoImg,
    format: "webp",
    width: 900,
    quality: 60,
});
