---
/**
 * ClientsShowcase — full-width clients image section with animated giant heading.
 *
 * Props:
 *   heading   — section heading
 *   lead      — italic subtitle
 *   color     — accent color (rule line)
 *   image     — ImageMetadata from astro:assets
 *   imageSrc  — fallback string src
 */

import { Image } from "astro:assets";

interface Props {
    heading?: string;
    lead?: string;
    color?: string;
    image?: any;
    imageSrc?: string;
}

const {
    heading = "Clienți de Încredere",
    lead = "Companii cu care am muncit împreună pentru siguranța echipelor de la audit inițial până la instruire și verificare periodică",
    color = "#111",
    image,
    imageSrc,
} = Astro.props;
---

<section class="py-16 lg:py-24 bg-white">
    <div class="px-5 lg:px-8">
        <!-- Heading with scroll-triggered entrance animation -->
        <div class="max-w-7xl mx-auto text-center mb-10 lg:mb-14">
            <div
                class="inline-block font-montserrat font-black text-[9px] uppercase tracking-widest px-3 py-1 mb-5 text-white"
                style={`background:${color};`}
            >
                Referințe
            </div>
            <h2
                class="font-montserrat font-black text-3xl lg:text-5xl uppercase tracking-tighter leading-none mb-4"
            >
                {heading}
            </h2>
            <div class="w-16 h-1 mx-auto mb-5" style={`background:${color};`}>
            </div>
            <p
                class="font-montserrat font-black text-sm md:text-base uppercase tracking-tight italic max-w-2xl mx-auto"
                style={`color:${color};`}
            >
                {lead}
            </p>
        </div>

        <!-- Image: clean, no shadow, no border -->
        <div class="mx-auto overflow-hidden" style="max-width:80.64rem;">
            {
                image ? (
                    <Image
                        src={image}
                        alt="Clienți WHTC - Companii Partenere"
                        width={1200}
                        quality={75}
                        format="webp"
                        class="w-full h-auto object-contain block"
                        loading="lazy"
                    />
                ) : imageSrc ? (
                    <img
                        src={imageSrc}
                        alt="Clienți WHTC - Companii Partenere"
                        class="w-full h-auto object-contain block"
                        loading="lazy"
                    />
                ) : null
            }
        </div>
    </div>
</section>
