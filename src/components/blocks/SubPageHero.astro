---
/**
 * SubPageHero — compact hero for /solutii/* sub-pages.
 *
 * Props:
 *   title      — main H1 (HTML allowed for <br/> breaks)
 *   subtitle   — small text below title (plain string)
 *   badge      — category label shown in coloured pill above H1
 *   color      — hex for badge bg and tint overlay (e.g. "#16a34a")
 *   bgImage    — background: imported ImageMetadata (Astro-optimized) OR a URL string
 */

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface CtaPrimary {
    label: string;
    subject: string;
}

interface CtaScroll {
    label: string;
    anchor: string; // without the # prefix
}

interface Props {
    title: string;
    subtitle?: string;
    badge?: string;
    color?: string;
    bgImage?: string | ImageMetadata;
    noGradient?: boolean; // suppress bottom fade-to-white
    fullHeight?: boolean; // make hero take full screen height
    ctaPrimary?: CtaPrimary; // opens contact drawer
    ctaScroll?: CtaScroll; // smooth-scrolls to page section
}

const {
    title,
    subtitle,
    badge,
    color = "#f16215",
    bgImage,
    noGradient = false,
    fullHeight = false,
    ctaPrimary,
    ctaScroll,
} = Astro.props;

const hasCtas = ctaPrimary || ctaScroll;
const bgIsLocal = bgImage && typeof bgImage !== "string";
---

<section
    class={`sub-hero relative bg-black text-white overflow-hidden pt-20 flex flex-col justify-center ${fullHeight ? "is-full-height" : ""}`}
    style="height: 100svh;"
>
    {/* Tinted colour wash */}
    <div
        class="absolute inset-0 z-0 pointer-events-none"
        style={`background:${color}; opacity:0.15;`}
    >
    </div>

    {/* Optional photo layer */}
    {
        bgImage && (
            <div class="absolute inset-0 z-0 pointer-events-none">
                {bgIsLocal ? (
                    <Image
                        src={bgImage as ImageMetadata}
                        alt=""
                        aria-hidden="true"
                        width={1600}
                        class="w-full h-full object-cover"
                        style="opacity:0.28; filter:grayscale(65%) contrast(1.15);"
                        loading="eager"
                        fetchpriority="high"
                        quality={60}
                        format="webp"
                    />
                ) : (
                    <Image
                        src={bgImage as string}
                        alt=""
                        aria-hidden="true"
                        width={1920}
                        height={1080}
                        inferSize={true}
                        class="w-full h-full object-cover"
                        style="opacity:0.22; filter:grayscale(70%) contrast(1.15);"
                        loading="eager"
                        fetchpriority="high"
                        quality={60}
                        format="webp"
                    />
                )}
                <div
                    class="absolute inset-0"
                    style="background:linear-gradient(to bottom,rgba(0,0,0,0.55) 0%,rgba(0,0,0,0.08) 50%,rgba(0,0,0,0.8) 100%);"
                />
            </div>
        )
    }

    {/* Accent line at very top of section */}
    <div
        class="absolute top-0 left-0 right-0 h-[3px] z-10"
        style={`background:${color};`}
    >
    </div>

    <div
        class="relative z-10 max-w-5xl mx-auto w-full px-5 lg:px-8 py-10 lg:py-14 text-center"
    >
        {
            badge && (
                <span
                    class="inline-block py-1 px-3 mb-3 lg:mb-5 font-montserrat font-black text-[9px] uppercase tracking-widest text-white"
                    style={`background:${color};`}
                >
                    {badge}
                </span>
            )
        }

        <h1
            class="hero-title font-montserrat font-black uppercase leading-none tracking-tighter mb-3 lg:mb-5"
            set:html={title}
        />

        {
            subtitle && (
                <p
                    class="text-white/60 max-w-2xl mx-auto font-montserrat font-bold uppercase tracking-widest text-[10px] md:text-xs leading-relaxed"
                    set:html={subtitle}
                />
            )
        }

        {/* ── Dual CTA Row ── */}
        {
            hasCtas && (
                <div class="flex flex-col sm:flex-row flex-wrap gap-3 justify-center mt-6 lg:mt-8">
                    {ctaPrimary && (
                        <button
                            onclick={`openContactDrawer('${ctaPrimary.subject}', '${color}')`}
                            class="hero-cta-primary flex items-center justify-center gap-2 px-7 py-3.5 font-montserrat font-black text-[11px] uppercase tracking-widest text-white transition-all duration-300"
                            style={`--hc:${color};`}
                        >
                            <svg
                                class="w-4 h-4 flex-shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                />
                            </svg>
                            {ctaPrimary.label}
                        </button>
                    )}
                    {ctaScroll && (
                        <a
                            href={`#${ctaScroll.anchor}`}
                            onclick={`event.preventDefault();const el=document.getElementById('${ctaScroll.anchor}');if(el){window.scrollTo({top:el.getBoundingClientRect().top+window.scrollY-80,behavior:'smooth'});}`}
                            class="flex items-center justify-center gap-2 px-7 py-3.5 font-montserrat font-black text-[11px] uppercase tracking-widest text-white border-2 border-white/30 hover:border-white hover:bg-white/10 transition-all duration-300"
                        >
                            {ctaScroll.label}
                            <svg
                                class="w-4 h-4 flex-shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"
                                />
                            </svg>
                        </a>
                    )}
                </div>
            )
        }
    </div>

    {/* Scroll hint arrow — absolutely pinned to bottom centre of section */}
    {
        ctaScroll && (
            <button
                onclick={`const el=document.getElementById('${ctaScroll.anchor}');if(el){window.scrollTo({top:el.getBoundingClientRect().top+window.scrollY-80,behavior:'smooth'});}`}
                aria-label="Scroll down"
                class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-1 text-white/40 hover:text-white transition-colors duration-300 cursor-pointer"
            >
                <svg
                    class="w-7 h-7 bounce-arrow"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M19 9l-7 7-7-7"
                    />
                </svg>
            </button>
        )
    }
</section>

<style>
    .hero-title {
        font-size: clamp(2.8rem, 7vw, 6rem);
    }
    .hero-cta-primary {
        background: var(--hc);
        cursor: pointer;
        border: 2px solid var(--hc);
    }
    .hero-cta-primary:hover {
        background: #111;
        border-color: #111;
    }
    /* Bouncing scroll arrow */
    @keyframes bounce-down {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(7px);
        }
    }
    .bounce-arrow {
        animation: bounce-down 1.8s ease-in-out infinite;
    }
    @media (min-width: 1920px) {
        .hero-title {
            font-size: clamp(4rem, 7vw, 8rem);
        }
    }
</style>
