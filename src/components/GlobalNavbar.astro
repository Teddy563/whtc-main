---
import { Image } from "astro:assets";
import whtcLogo from "../assets/whtc.svg";
import SharedContactDrawer from "./SharedContactDrawer.astro";

// ─── Navigation Data ──────────────────────────────────────────────────────────
// Simplified: Soluții Protecție shows 5 main items on hover.
// Training and Control Energii are direct links.

const solutiiItems = [
    {
        label: "Sisteme Linia Vieții",
        href: "/solutii/linia-vietii/",
        color: "#1e3a8a",
        tag: "Inginerie",
    },
    {
        label: "Verificări & Recertificări",
        href: "/solutii/verificari-recertificari/",
        color: "#16a34a",
        tag: "EIP",
    },
    {
        label: "Scări & Platforme",
        href: "/solutii/acces/",
        color: "#7c3aed",
        tag: "Acces",
    },
    {
        label: "Echipamente 3M™",
        href: "/solutii/3m/",
        color: "#D32F2F",
        tag: "Distribuție",
    },
    {
        label: "Implementare Custom",
        href: "/solutii/custom/",
        color: "#f16215",
        tag: "Full Service",
    },
];
---

<header
    class="fixed top-0 left-0 right-0 z-[100] bg-white border-b border-gray-200 shadow-sm font-montserrat"
    id="global-navbar"
>
    <div
        class="flex items-center justify-between h-20 px-5 lg:px-8 max-w-[1920px] mx-auto relative bg-white z-[101]"
    >
        <!-- Logo -->
        <a
            href="/"
            class="flex items-center gap-4 flex-shrink-0"
            aria-label="WHTC – Acasă"
        >
            <Image
                src={whtcLogo}
                alt="WHTC Logo"
                class="h-10 lg:h-12 w-auto"
                loading="eager"
                fetchpriority="high"
            />
            <div class="hidden xl:block h-8 w-px bg-gray-200 mx-1"></div>
            <span
                class="hidden xl:block font-bold text-[10px] uppercase tracking-[0.2em] text-gray-500 leading-tight"
            >
                Working at Height<br />Training Centre
            </span>
        </a>

        <!-- Right Side Container: Nav + Actions -->
        <div class="flex items-center gap-6 ml-auto">
            <!-- Desktop Navigation -->
            <nav
                class="hidden lg:flex items-center gap-2 h-full"
                aria-label="Navigare principală"
            >
                <!-- Soluții Protecție — Compact anchored dropdown -->
                <div class="nav-item group h-full flex items-center relative">
                    <a
                        href="/solutii/"
                        class="nav-link flex items-center gap-1 px-3 py-2 font-bold text-[12px] uppercase tracking-wider text-gray-800 hover:text-brand-orange transition-colors"
                        aria-label="Soluții Protecție"
                    >
                        Soluții Protecție
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                            focusable="false"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </a>
                    <!-- Compact dropdown panel — anchored below button, not full-width -->
                    <div
                        class="absolute top-full left-0 mt-0 w-72 bg-white border border-gray-200 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform -translate-y-1 group-hover:translate-y-0 z-[99]"
                    >
                        <div class="divide-y divide-gray-100">
                            {
                                solutiiItems.map((item) => (
                                    <a
                                        href={item.href}
                                        class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group/si"
                                    >
                                        <span
                                            class="w-2 h-2 rounded-full flex-shrink-0"
                                            style={`background: ${item.color};`}
                                        />
                                        <div>
                                            <span class="block font-montserrat font-black text-[12px] text-gray-900 leading-tight uppercase tracking-tight">
                                                {item.label}
                                            </span>
                                            <span
                                                class="block text-[9px] font-bold uppercase tracking-[.2em]"
                                                style={`color: ${item.color};`}
                                            >
                                                {item.tag}
                                            </span>
                                        </div>
                                    </a>
                                ))
                            }
                        </div>
                        <div class="border-t border-gray-100 px-4 py-2.5">
                            <a
                                href="/solutii/"
                                class="text-[10px] font-black uppercase tracking-widest text-gray-500 hover:text-brand-orange transition-colors flex items-center gap-1"
                            >
                                Vezi toate soluțiile
                                <svg
                                    class="w-3 h-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                    focusable="false"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M14 5l7 7m0 0l-7 7m7-7H3"
                                    ></path></svg
                                >
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Training — Direct link -->
                <a
                    href="/training-lucru-la-inaltime/"
                    class="nav-link px-3 py-2 font-bold text-[12px] uppercase tracking-wider text-gray-800 hover:text-brand-orange-alt transition-colors"
                >
                    Training
                </a>

                <!-- Control Energii — Direct link -->
                <a
                    href="/control-energii-lockout-tagout/"
                    class="nav-link px-3 py-2 font-bold text-[12px] uppercase tracking-wider text-gray-800 hover:text-brand-red transition-colors"
                >
                    Control Energii
                </a>
            </nav>

            <div class="flex items-center gap-4">
                <!-- Contact Expert Button -->
                <button
                    onclick="openContactDrawer()"
                    class="hidden sm:flex items-center justify-center bg-black text-white px-6 font-bold text-[11px] uppercase tracking-[0.15em] hover:bg-gray-800 transition-all duration-300 shadow-sm border border-black"
                    style="height: 48px;"
                >
                    Contact Expert
                </button>

                <!-- Phone Button -->
                <div class="relative hidden sm:block">
                    <button
                        onclick="togglePhoneDropdown()"
                        class="flex items-center justify-center w-12 bg-white border border-gray-300 hover:border-black hover:text-black text-gray-700 transition-colors relative z-10 box-border"
                        aria-label="Call Expert"
                        style="height: 48px; width: 48px;"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                            focusable="false"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path></svg
                        >
                    </button>

                    <!-- Phone Dropdown -->
                    <div
                        id="phone-dropdown"
                        class="absolute top-full right-0 mt-2 w-72 bg-white border border-gray-200 shadow-xl p-6 hidden flex-col gap-4 transform origin-top-right transition-all z-20 rounded-sm"
                    >
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase text-gray-400 tracking-widest mb-1"
                                >Email Rapid</span
                            >
                            <a
                                href="mailto:office@whtc.ro"
                                class="block font-bold text-sm text-gray-800 hover:text-brand-orange transition-colors"
                                >office@whtc.ro</a
                            >
                        </div>
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase text-gray-400 tracking-widest mb-1"
                                >Telefon</span
                            >
                            <a
                                href="tel:+40749225956"
                                class="block font-black text-lg text-gray-900 hover:text-brand-orange transition-colors"
                                >+40 749 225 956</a
                            >
                        </div>
                        <div
                            class="pt-4 border-t border-gray-100 flex items-center gap-2"
                            id="phone-status-container"
                        >
                            <!-- Status populated by JS -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile Menu Toggle -->
            <button
                aria-label="Deschide meniu de navigare"
                aria-expanded="false"
                aria-controls="mobile-menu"
                class="lg:hidden p-2 text-black ml-4"
                onclick="const m=document.getElementById('mobile-menu');const open=m.classList.toggle('hidden');this.setAttribute('aria-expanded',String(!open));"
            >
                <svg
                    class="w-8 h-8"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    focusable="false"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path></svg
                >
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu Overlay -->
<nav
    id="mobile-menu"
    aria-label="Navigare mobilă"
    class="hidden lg:hidden fixed top-[80px] left-0 w-full h-[calc(100vh-80px)] bg-white border-t border-gray-200 shadow-xl py-6 px-6 flex flex-col gap-6 overflow-y-auto z-[90]"
>
    <div class="space-y-4 mt-2">
        <!-- Soluții Protecție Section -->
        <div>
            <div class="flex items-center justify-between mb-3">
                <h3
                    class="font-black text-xs uppercase text-gray-400 tracking-[0.2em]"
                >
                    Soluții Protecție
                </h3>
                <a
                    href="/solutii/"
                    class="text-[10px] font-black uppercase tracking-widest text-brand-orange hover:underline"
                >
                    Vezi Toate →
                </a>
            </div>
            <div class="space-y-2">
                {
                    solutiiItems.map((item) => (
                        <a
                            href={item.href}
                            class="flex items-center gap-3 py-3 px-3 rounded border border-gray-100 hover:border-gray-300 hover:bg-gray-50 transition-colors"
                        >
                            <span
                                class="w-1.5 h-1.5 rounded-full flex-shrink-0"
                                style={`background: ${item.color};`}
                            />
                            <span class="font-montserrat font-black text-[12px] uppercase tracking-tight text-gray-800">
                                {item.label}
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-100"></div>

        <!-- Training -->
        <a
            href="/training-lucru-la-inaltime/"
            class="flex items-center justify-between py-3 px-3 rounded border border-gray-100 hover:border-gray-300 hover:bg-gray-50 transition-colors"
        >
            <span
                class="font-montserrat font-black text-[12px] uppercase tracking-wider text-gray-800"
            >
                Training
            </span>
            <svg
                class="w-4 h-4 text-gray-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path></svg
            >
        </a>

        <!-- Control Energii -->
        <a
            href="/control-energii-lockout-tagout/"
            class="flex items-center justify-between py-3 px-3 rounded border border-gray-100 hover:border-gray-300 hover:bg-gray-50 transition-colors"
        >
            <span
                class="font-montserrat font-black text-[12px] uppercase tracking-wider text-gray-800"
            >
                Control Energii
            </span>
            <svg
                class="w-4 h-4 text-gray-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path></svg
            >
        </a>
    </div>

    <div
        class="mt-auto pt-6 text-center space-y-4 border-t border-gray-100 pb-10"
    >
        <div
            class="flex items-center justify-center gap-4 mb-4"
            id="mobile-status-container"
        >
            <!-- Status populated by JS -->
        </div>
        <a
            href="tel:+40749225956"
            class="block w-full border border-gray-300 py-3 font-bold uppercase text-xs tracking-widest hover:bg-black hover:text-white transition-colors rounded-sm"
        >
            Suna Acum
        </a>
        <button
            onclick="openContactDrawer()"
            class="block w-full bg-black text-white py-4 font-bold uppercase text-xs tracking-[0.2em] hover:bg-gray-800 transition-colors rounded-sm"
        >
            Contact Expert
        </button>
    </div>
</nav>

<!-- The shared contact drawer -->
<SharedContactDrawer />

<script is:inline>
    // Phone Dropdown Logic
    window.togglePhoneDropdown = function () {
        const dd = document.getElementById("phone-dropdown");
        if (dd) {
            dd.classList.toggle("hidden");
            dd.classList.toggle("flex");
            updateWorkStatus();
        }
    };

    // Work Status Logic
    function updateWorkStatus() {
        const now = new Date();
        const day = now.getDay();
        const hour = now.getHours();

        const isWorkingDay = day >= 1 && day <= 5;
        const isWorkingHour = hour >= 9 && hour < 17;
        const isOpen = isWorkingDay && isWorkingHour;

        const statusHtml = isOpen
            ? `<div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
               <span class="text-[10px] font-bold text-green-700 uppercase tracking-wide">Disponibil Acum (09:00 - 17:00)</span>`
            : `<div class="w-2 h-2 rounded-full bg-gray-400"></div>
               <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wide">În afara programului (L-V 09-17)</span>`;

        const container = document.getElementById("phone-status-container");
        if (container) container.innerHTML = statusHtml;

        const mobileContainer = document.getElementById(
            "mobile-status-container",
        );
        if (mobileContainer) mobileContainer.innerHTML = statusHtml;
    }

    // Run on load
    updateWorkStatus();

    // Close phone dropdown when clicking outside
    document.addEventListener("click", function (event) {
        const dd = document.getElementById("phone-dropdown");
        const btn = event.target.closest(
            'button[onclick="togglePhoneDropdown()"]',
        );
        if (
            dd &&
            !dd.classList.contains("hidden") &&
            !dd.contains(event.target) &&
            !btn
        ) {
            dd.classList.add("hidden");
            dd.classList.remove("flex");
        }
    });
</script>
