---
import { Image } from "astro:assets";
import whtcLogo from "../assets/whtc.svg";
import SharedContactDrawer from "./SharedContactDrawer.astro";

// ─── Navigation Data ──────────────────────────────────────────────────────────
// Each category has a hub page href, an accent colour, a subtitle, and up to 5
// sub-links. Editing this object is the only thing needed to update the nav.

interface SubItem {
    label: string;
    href: string;
}
interface NavCategory {
    label: string;
    href: string;
    color: string;
    desc: string;
    items: SubItem[];
}

const solutiiCategories: NavCategory[] = [
    {
        label: "Inginerie",
        href: "/solutii/inginerie/",
        color: "#1e3a8a",
        desc: "Proiectare și Montaj",
        items: [
            {
                label: "Sisteme Linia Vieții",
                href: "/solutii/linia-vietii/",
            },
            {
                label: "Ancore Structurale și Daviți",
                href: "/solutii/inginerie/ancore-structurale/",
            },
            {
                label: "Protecție Colectivă",
                href: "/solutii/inginerie/protectie-colectiva/",
            },
            {
                label: "Sisteme Acces Permanent",
                href: "/solutii/inginerie/acces-permanent/",
            },
            {
                label: "Proiectare, Audit și Montaj",
                href: "/solutii/inginerie/proiectare-montaj/",
            },
        ],
    },
    {
        label: "Echipamente 3M™",
        href: "/solutii/echipamente-3m/",
        color: "#D32F2F",
        desc: "Distribuitor Autorizat",
        items: [
            {
                label: "Echipamente Anticădere",
                href: "/solutii/echipamente-3m/echipamente-anticadere/",
            },
            {
                label: "Protecție Cap, Față și Ochi",
                href: "/solutii/echipamente-3m/protectie-cap-fata-ochi/",
            },
            {
                label: "Protecție Respiratorie și Auditivă",
                href: "/solutii/echipamente-3m/protectie-respiratorie-auditiva/",
            },
            {
                label: "Kituri de Salvare și Evacuare",
                href: "/solutii/echipamente-3m/rescue-si-evacuare/",
            },
            {
                label: "Consultanță Alegere Produse",
                href: "/solutii/echipamente-3m/consultanta-alegere-produse/",
            },
        ],
    },
    {
        label: "Verificări",
        href: "/solutii/verificari-recertificari/",
        color: "#16a34a",
        desc: "Inspecție și Recertificări",
        items: [
            {
                label: "Inspecție Echipamente (EIP)",
                href: "/solutii/verificari-recertificari/echipamente-anticadere-ppe/",
            },
            {
                label: "Testare Linia Vieții",
                href: "/solutii/verificari-recertificari/linia-vietii-si-sisteme-fixe/",
            },
            {
                label: "Certificare Scări și Platforme",
                href: "/solutii/verificari-recertificari/scari-si-platforme/",
            },
            {
                label: "Program Mentenanță Periodică",
                href: "/solutii/verificari-recertificari/program-periodic-pe-site/",
            },
        ],
    },
    {
        label: "Scări și Platforme",
        href: "/solutii/scari-platforme/",
        color: "#7c3aed",
        desc: "Acces Industrial",
        items: [
            {
                label: "Scări Fixe și Scări cu Cușcă",
                href: "/solutii/scari-platforme/scari-exterioare-fixe/",
            },
            {
                label: "Platforme Permanente pe Clădire",
                href: "/solutii/scari-platforme/platforme-permanente-pe-cladire/",
            },
            {
                label: "Platforme Modulare și Temporare",
                href: "/solutii/scari-platforme/platforme-temporare-si-modulare/",
            },
            {
                label: "Treceri Tehnologice (Step-over)",
                href: "/solutii/scari-platforme/step-over-si-treceri-tehnologice/",
            },
        ],
    },
    {
        label: "Personalizate",
        href: "/solutii/implementare-custom/",
        color: "#f16215",
        desc: "Soluții Complete",
        items: [
            {
                label: "Audit la Fața Locului (Site Survey)",
                href: "/solutii/implementare-custom/pachet-site-survey/",
            },
            {
                label: "Proiectare și Bugetare",
                href: "/solutii/implementare-custom/proiectare-si-bugetare/",
            },
            {
                label: "Documentație și Instruire Echipă",
                href: "/solutii/implementare-custom/documentatie-si-instruire/",
            },
        ],
    },
];

const trainingItems = [
    {
        label: "Cursuri GWO",
        href: "#",
        desc: "Certificări eoliene internaționale",
    },
    { label: "Cursuri IRATA", href: "#", desc: "Alpinism utilitar industrial" },
    {
        label: "Safety Academy",
        href: "#",
        desc: "Cursuri customizate & workshop-uri",
    },
];

const lotoItems = [
    {
        label: "Audit & Consultanță",
        href: "#",
        desc: "Analiză riscuri & proceduri",
    },
    {
        label: "Proceduri LOTO",
        href: "#",
        desc: "Implementare sistem Lockout/Tagout",
    },
    { label: "Echipamente", href: "#", desc: "Lacate, blocatoare & accesorii" },
];
---

<header
    class="fixed top-0 left-0 right-0 z-[100] bg-white border-b border-gray-200 shadow-sm font-montserrat"
    id="global-navbar"
>
    <div
        class="flex items-center justify-between h-20 px-5 lg:px-8 max-w-[1920px] mx-auto relative bg-white z-[101]"
    >
        <!-- Logo -->
        <a href="/" class="flex items-center gap-4 flex-shrink-0">
            <Image
                src={whtcLogo}
                alt="WHTC Logo"
                class="h-10 lg:h-12 w-auto"
                loading="eager"
                fetchpriority="high"
            />
            <div class="hidden xl:block h-8 w-px bg-gray-200 mx-1"></div>
            <span
                class="hidden xl:block font-bold text-[10px] uppercase tracking-[0.2em] text-gray-500 leading-tight"
            >
                Working at Height<br />Training Centre
            </span>
        </a>

        <!-- Right Side Container: Nav + Actions -->
        <div class="flex items-center gap-6 ml-auto">
            <!-- Desktop Navigation -->
            <nav class="hidden lg:flex items-center gap-4 h-full">
                <!-- Dropdown: Solutii -->
                <div class="nav-item group h-full flex items-center">
                    <button
                        aria-label="Soluții Protecție - menü navigare"
                        class="nav-link flex items-center gap-1 px-3 py-2 font-bold text-[12px] uppercase tracking-wider text-gray-800 hover:text-brand-orange transition-colors"
                    >
                        Soluții Protecție
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <!-- Mega Menu (Full Width — Nested Silo) -->
                    <div
                        class="fixed top-[80px] left-0 w-full bg-white border-b border-gray-200 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 p-0 transform -translate-y-2 group-hover:translate-y-0 z-[99]"
                    >
                        <!-- Top accent bar driven by JS hover; static fallback = brand-orange -->
                        <div
                            id="mega-accent-bar"
                            class="h-[3px] w-full transition-all duration-200"
                            style="background:#f16215;"
                        >
                        </div>

                        <div class="max-w-[1920px] mx-auto px-8 py-7">
                            <!-- Category header row -->
                            <div
                                class="grid grid-cols-5 divide-x divide-gray-100 border-none mb-0"
                            >
                                {
                                    solutiiCategories.map((cat) => (
                                        <a
                                            href={cat.href}
                                            class="mega-cat-header group/cat flex flex-col px-5 py-4 bg-white hover:bg-gray-50 transition-colors"
                                            data-color={cat.color}
                                        >
                                            <span
                                                class="font-montserrat font-black text-[13px] sm:text-[14px] uppercase tracking-wider text-gray-900 group-hover/cat:transition-colors mb-0.5 mega-cat-label"
                                                style={`transition:color .15s; line-height: 1.1;`}
                                            >
                                                {cat.label}
                                            </span>
                                            <span class="text-[11px] sm:text-[12px] text-gray-500 font-bold uppercase tracking-widest leading-tight block">
                                                {cat.desc}
                                            </span>
                                        </a>
                                    ))
                                }
                            </div>

                            <!-- Sub-link rows -->
                            <div
                                class="grid grid-cols-5 divide-x divide-gray-100 border-t border-gray-100"
                            >
                                {
                                    solutiiCategories.map((cat) => (
                                        <ul class="bg-white py-3 px-2 space-y-0.5">
                                            {cat.items.map((item) => (
                                                <li>
                                                    <a
                                                        href={item.href}
                                                        class="mega-sublink flex items-center gap-3 px-3 py-2.5 text-[12px] sm:text-[13px] text-gray-700 font-semibold hover:text-gray-900 rounded-sm transition-colors hover:bg-gray-50"
                                                        data-color={cat.color}
                                                    >
                                                        <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 bg-gray-300 mega-sublink-dot transition-colors" />
                                                        {item.label}
                                                    </a>
                                                </li>
                                            ))}
                                        </ul>
                                    ))
                                }
                            </div>

                            <!-- Footer bar: view all link -->
                            <div
                                class="pt-4 flex items-center justify-between border-t border-gray-100 mt-1"
                            >
                                <span
                                    class="text-[11px] font-black uppercase tracking-[.2em] text-gray-400"
                                    >Soluții Protecție WHTC</span
                                >
                                <a
                                    href="/solutii/"
                                    class="text-[12px] font-black uppercase tracking-widest text-gray-600 hover:text-brand-orange transition-colors flex items-center gap-1"
                                >
                                    Vezi toate soluțiile
                                    <svg
                                        class="w-4 h-4 inline-block"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"
                                        ></path></svg
                                    >
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dropdown: Training -->
                <div class="nav-item group h-full flex items-center">
                    <button
                        aria-label="Training - menü navigare"
                        class="nav-link flex items-center gap-1 px-3 py-2 font-bold text-[12px] uppercase tracking-wider text-gray-800 hover:text-brand-orange-alt transition-colors"
                    >
                        Training
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="fixed top-[80px] left-0 w-full bg-white border-b border-gray-200 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 p-0 transform -translate-y-2 group-hover:translate-y-0 z-[99]"
                    >
                        <div class="max-w-[1920px] mx-auto px-8 py-8">
                            <div class="grid grid-cols-4 gap-8">
                                {
                                    trainingItems.map((item) => (
                                        <a
                                            href={item.href}
                                            class="group/item flex flex-col p-4 hover:bg-gray-50 transition-colors border-l-2 border-transparent hover:border-brand-orange-alt rounded-sm"
                                        >
                                            <span class="font-bold text-[13px] text-gray-800 group-hover/item:text-brand-orange-alt uppercase tracking-wide">
                                                {item.label}
                                            </span>
                                            <span class="text-[10px] text-gray-500 group-hover/item:text-gray-600 font-medium mt-1">
                                                {item.desc}
                                            </span>
                                        </a>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dropdown: LOTO -->
                <div class="nav-item group h-full flex items-center">
                    <button
                        aria-label="Control Energii Periculoase - menü navigare"
                        class="nav-link flex items-center gap-1 px-3 py-2 font-bold text-[12px] uppercase tracking-wider text-gray-800 hover:text-brand-red transition-colors"
                    >
                        Control Energii
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="fixed top-[80px] left-0 w-full bg-white border-b border-gray-200 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 p-0 transform -translate-y-2 group-hover:translate-y-0 z-[99]"
                    >
                        <div class="max-w-[1920px] mx-auto px-8 py-8">
                            <div class="grid grid-cols-4 gap-8">
                                {
                                    lotoItems.map((item) => (
                                        <a
                                            href={item.href}
                                            class="group/item flex flex-col p-4 hover:bg-gray-50 transition-colors border-l-2 border-transparent hover:border-brand-red rounded-sm"
                                        >
                                            <span class="font-bold text-[13px] text-gray-800 group-hover/item:text-brand-red uppercase tracking-wide">
                                                {item.label}
                                            </span>
                                            <span class="text-[10px] text-gray-500 group-hover/item:text-gray-600 font-medium mt-1">
                                                {item.desc}
                                            </span>
                                        </a>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="flex items-center gap-4">
                <!-- Contact Expert Button (Left) -->
                <button
                    onclick="openContactDrawer()"
                    class="hidden sm:flex items-center justify-center bg-black text-white px-6 font-bold text-[11px] uppercase tracking-[0.15em] hover:bg-gray-800 transition-all duration-300 shadow-sm border border-black"
                    style="height: 48px;"
                >
                    Contact Expert
                </button>

                <!-- Phone Button (Right) -->
                <div class="relative hidden sm:block">
                    <button
                        onclick="togglePhoneDropdown()"
                        class="flex items-center justify-center w-12 bg-white border border-gray-300 hover:border-black hover:text-black text-gray-700 transition-colors relative z-10 box-border"
                        aria-label="Call Expert"
                        style="height: 48px; width: 48px;"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path></svg
                        >
                    </button>

                    <!-- Phone Dropdown -->
                    <div
                        id="phone-dropdown"
                        class="absolute top-full right-0 mt-2 w-72 bg-white border border-gray-200 shadow-xl p-6 hidden flex-col gap-4 transform origin-top-right transition-all z-20 rounded-sm"
                    >
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase text-gray-400 tracking-widest mb-1"
                                >Email Rapid</span
                            >
                            <a
                                href="mailto:office@whtc.ro"
                                class="block font-bold text-sm text-gray-800 hover:text-brand-orange transition-colors"
                                >office@whtc.ro</a
                            >
                        </div>
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase text-gray-400 tracking-widest mb-1"
                                >Telefon</span
                            >
                            <a
                                href="tel:+40749225956"
                                class="block font-black text-lg text-gray-900 hover:text-brand-orange transition-colors"
                                >+40 749 225 956</a
                            >
                        </div>
                        <div
                            class="pt-4 border-t border-gray-100 flex items-center gap-2"
                            id="phone-status-container"
                        >
                            <!-- Status populated by JS -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile Menu Toggle -->
            <button
                aria-label="Deschide meniu de navigare"
                class="lg:hidden p-2 text-black ml-4"
                onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
            >
                <svg
                    class="w-8 h-8"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path></svg
                >
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu Overlay -->
<div
    id="mobile-menu"
    class="hidden lg:hidden fixed top-[80px] left-0 w-full h-[calc(100vh-80px)] bg-white border-t border-gray-200 shadow-xl py-6 px-6 flex flex-col gap-6 overflow-y-auto z-[90]"
>
    <div class="space-y-2 mt-4">
        <!-- Soluții accordion (CSS-only) -->
        <h3
            class="font-bold text-xs uppercase text-gray-400 tracking-[0.2em] border-b border-gray-100 pb-2 mb-2"
        >
            Soluții Protecție
        </h3>
        {
            solutiiCategories.map((cat) => (
                <details class="mob-accordion border-gray-50 group/mob rounded border mb-2 overflow-hidden shadow-sm">
                    <summary
                        class="flex items-center justify-between py-3.5 px-3 font-montserrat font-black text-[12px] uppercase tracking-[.10em] text-gray-800 cursor-pointer list-none select-none bg-gray-50/50 hover:bg-gray-100/50 transition-colors"
                        style={`--mc:${cat.color}; border-left: 3px solid ${cat.color};`}
                    >
                        <span class="mob-cat-label">{cat.label}</span>
                        <svg
                            class="w-3.5 h-3.5 text-gray-500 transition-transform duration-200 group-open/mob:rotate-180 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"
                            />
                        </svg>
                    </summary>
                    <ul class="pb-2 pt-2 px-3 space-y-1 bg-white">
                        {cat.items.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="flex items-start gap-3 py-2.5 px-2 text-[12px] font-semibold text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors rounded-sm"
                                >
                                    <span
                                        class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-1"
                                        style={`background:${cat.color};`}
                                    />
                                    <span class="leading-tight">
                                        {item.label}
                                    </span>
                                </a>
                            </li>
                        ))}
                        <li>
                            <a
                                href={cat.href}
                                class="flex items-center gap-2 mt-2 py-3 px-2 text-[12px] font-black uppercase tracking-wider bg-gray-50 hover:bg-gray-100 transition-colors rounded-sm justify-between border border-gray-100"
                                style={`color:${cat.color};`}
                            >
                                <span>Vezi Toate {cat.label}</span>
                                <span>→</span>
                            </a>
                        </li>
                    </ul>
                </details>
            ))
        }

        <div class="space-y-3">
            <h3
                class="font-bold text-xs uppercase text-gray-400 tracking-[0.2em] border-b border-gray-100 pb-2"
            >
                Training
            </h3>
            <div class="grid grid-cols-1 gap-2 pl-2">
                {
                    trainingItems.map((item) => (
                        <a
                            href={item.href}
                            class="flex items-center justify-between py-2 text-sm font-bold text-gray-800 hover:text-brand-orange-alt group"
                        >
                            <span>{item.label}</span>
                        </a>
                    ))
                }
            </div>
        </div>

        <div class="space-y-3">
            <h3
                class="font-bold text-xs uppercase text-gray-400 tracking-[0.2em] border-b border-gray-100 pb-2"
            >
                LOTO
            </h3>
            <div class="grid grid-cols-1 gap-2 pl-2">
                {
                    lotoItems.map((item) => (
                        <a
                            href={item.href}
                            class="flex items-center justify-between py-2 text-sm font-bold text-gray-800 hover:text-brand-red group"
                        >
                            <span>{item.label}</span>
                        </a>
                    ))
                }
            </div>
        </div>
    </div>

    <div
        class="mt-auto pt-6 text-center space-y-4 border-t border-gray-100 pb-10"
    >
        <div
            class="flex items-center justify-center gap-4 mb-4"
            id="mobile-status-container"
        >
            <!-- Status populated by JS -->
        </div>
        <a
            href="tel:+40749225956"
            class="block w-full border border-gray-300 py-3 font-bold uppercase text-xs tracking-widest hover:bg-black hover:text-white transition-colors rounded-sm"
        >
            Suna Acum
        </a>
        <button
            onclick="openContactDrawer()"
            class="block w-full bg-black text-white py-4 font-bold uppercase text-xs tracking-[0.2em] hover:bg-gray-800 transition-colors rounded-sm"
        >
            Contact Expert
        </button>
    </div>
</div>

<!-- The shared contact drawer is now a standalone component -->
<SharedContactDrawer />

<script is:inline>
    // Phone Dropdown Logic
    window.togglePhoneDropdown = function () {
        const dd = document.getElementById("phone-dropdown");
        if (dd) {
            dd.classList.toggle("hidden");
            dd.classList.toggle("flex");
            updateWorkStatus();
        }
    };

    // Work Status Logic
    function updateWorkStatus() {
        const now = new Date();
        const day = now.getDay();
        const hour = now.getHours();

        const isWorkingDay = day >= 1 && day <= 5;
        const isWorkingHour = hour >= 9 && hour < 17;
        const isOpen = isWorkingDay && isWorkingHour;

        const statusHtml = isOpen
            ? `<div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
               <span class="text-[10px] font-bold text-green-700 uppercase tracking-wide">Disponibil Acum (09:00 - 17:00)</span>`
            : `<div class="w-2 h-2 rounded-full bg-gray-400"></div>
               <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wide">În afara programului (L-V 09-17)</span>`;

        const container = document.getElementById("phone-status-container");
        if (container) container.innerHTML = statusHtml;

        const mobileContainer = document.getElementById(
            "mobile-status-container",
        );
        if (mobileContainer) mobileContainer.innerHTML = statusHtml;
    }

    // Run on load
    updateWorkStatus();

    // Close phone dropdown when clicking outside
    document.addEventListener("click", function (event) {
        const dd = document.getElementById("phone-dropdown");
        const btn = event.target.closest(
            'button[onclick="togglePhoneDropdown()"]',
        );
        if (
            dd &&
            !dd.classList.contains("hidden") &&
            !dd.contains(event.target) &&
            !btn
        ) {
            dd.classList.add("hidden");
            dd.classList.remove("flex");
        }
    });

    // ─── Mega-menu colour accent on hover ────────────────────────────────────
    (function () {
        const accentBar = document.getElementById("mega-accent-bar");

        // Category headers — colour the label + accent bar on hover
        document.querySelectorAll(".mega-cat-header").forEach(function (el) {
            const color = el.getAttribute("data-color") || "#f16215";
            const label = el.querySelector(".mega-cat-label");

            el.addEventListener("mouseenter", function () {
                if (accentBar) accentBar.style.background = color;
                if (label) label.style.color = color;
            });
            el.addEventListener("mouseleave", function () {
                if (label) label.style.color = "";
            });
        });

        // Sub-links — colour the dot and text on hover
        document.querySelectorAll(".mega-sublink").forEach(function (el) {
            const color = el.getAttribute("data-color") || "#f16215";
            const dot = el.querySelector(".mega-sublink-dot");

            el.addEventListener("mouseenter", function () {
                el.style.color = color;
                if (dot) dot.style.background = color;
            });
            el.addEventListener("mouseleave", function () {
                el.style.color = "";
                if (dot) dot.style.background = "";
            });
        });

        // Mobile accordion — colour the summary label when open
        document.querySelectorAll(".mob-accordion").forEach(function (el) {
            const color =
                el.querySelector("summary")?.style.getPropertyValue("--mc") ||
                "#f16215";
            const label = el.querySelector(".mob-cat-label");

            el.addEventListener("toggle", function () {
                if (label) label.style.color = el.open ? color : "";
            });
        });
    })();
</script>
