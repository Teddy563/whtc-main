---
import Layout from "../layouts/Layout.astro";
import SharedContactDrawer from "../components/SharedContactDrawer.astro";
import GlobalNavbar from "../components/GlobalNavbar.astro";
---

<Layout title="Contact - Working Height Training Centre SRL">
    <GlobalNavbar />
    <main class="min-h-screen bg-[#fafafa] flex flex-col pt-24 font-montserrat">
        <div class="max-w-4xl mx-auto w-full px-6 py-12 flex-grow">
            <!-- Header -->
            <div class="mb-12">
                <span
                    class="text-xs font-black uppercase tracking-[0.2em] text-gray-500 mb-4 block"
                    >Cum te putem ajuta?</span
                >
                <h1
                    class="text-4xl md:text-5xl lg:text-6xl font-black uppercase leading-none tracking-tighter text-black mb-6"
                >
                    Contactează<br />Echipa Noastră
                </h1>
                <div class="w-16 h-2" style="background-color: #f16215;"></div>
            </div>

            <!-- Content Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- Info Section -->
                <div class="space-y-8">
                    <p class="text-lg text-gray-700 font-medium">
                        Suntem aici pentru a răspunde întrebărilor tale despre
                        cursurile de lucru la înălțime, soluțiile de protecție
                        sau echipamentele 3M™.
                    </p>

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div
                                class="w-12 h-12 bg-black text-white flex items-center justify-center flex-shrink-0"
                            >
                                <svg
                                    class="w-6 h-6"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <h3
                                    class="text-sm font-black uppercase tracking-widest text-gray-400 mb-1"
                                >
                                    Telefon
                                </h3>
                                <a
                                    href="tel:+40749225956"
                                    class="text-xl font-bold text-black hover:text-[#f16215] transition-colors"
                                    >+40 749 225 956</a
                                >
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="w-12 h-12 bg-black text-white flex items-center justify-center flex-shrink-0"
                            >
                                <svg
                                    class="w-6 h-6"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <h3
                                    class="text-sm font-black uppercase tracking-widest text-gray-400 mb-1"
                                >
                                    Email
                                </h3>
                                <a
                                    href="mailto:office@whtc.ro"
                                    class="text-xl font-bold text-black hover:text-[#f16215] transition-colors"
                                    >office@whtc.ro</a
                                >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Section -->
                <div
                    class="bg-white border-2 border-black p-8 flex flex-col justify-center"
                >
                    <h3 class="text-2xl font-black uppercase mb-4">
                        Trimite un Mesaj
                    </h3>
                    <p class="text-gray-600 mb-8 font-medium">
                        Ai nevoie de o ofertă personalizată sau vrei să
                        programezi un curs? Folosește formularul nostru de
                        contact rapid.
                    </p>

                    <button
                        onclick="openContactDrawer('Contact Pagina Generala', '#f16215')"
                        class="w-full bg-black text-white py-5 font-black uppercase tracking-[0.2em] text-sm flex items-center justify-center gap-3 transition-all ease-in-out hover:bg-[#f16215] active:scale-[0.98] border-2 border-black hover:border-[#f16215]"
                    >
                        <span>Deschide Formularul</span>
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                        >
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Drawer component is included so that `openContactDrawer` works on this page -->
    <SharedContactDrawer />
</Layout>
